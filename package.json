{
  "name": "ai-framework-gb",
  "version": "1.0.0",
  "private": true,
  "description": "AI newsletter site + Remotion ambient hero loop. One-command runner, deploy-safe for Railway and GitHub Pages.",
  "scripts": {
    "postinstall": "npm --prefix remotion-hero install --prefer-offline --no-audit --no-fund",
    "prepare": "husky",
    "render": "npm --prefix remotion-hero run build",
    "render:webm": "npm --prefix remotion-hero run build:webm",
    "render:if-missing": "node scripts/render-if-needed.mjs",
    "build:prompts": "node scripts/build-prompts.mjs",
    "build:site": "npm run build:prompts && vite build",
    "build": "npm run render:if-missing && npm run build:site",
    "dev:web": "npm run build:prompts && vite --host 0.0.0.0 --port ${PORT:-5173}",
    "serve": "vite preview --host 0.0.0.0 --port ${PORT:-5173}",
    "studio": "cd remotion-hero && npm start",
    "start": "node scripts/start.js",
    "start:railway": "npm run serve",
    "dev": "concurrently -k -n web,studio -c green,blue \"npm run dev:web\" \"npm run studio\"",
    "force-render": "npm run render && npm run build:site && npm run serve",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:styles": "stylelint \"src/styles/**/*.css\"",
    "lint:staged": "lint-staged",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:remotion && npm run test:e2e",
    "test:e2e": "playwright test",
    "test:remotion": "node --test tests/remotion-render.test.mjs",
    "scan:secrets": "node scripts/secret-scan.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "lint-staged": {
    "*.{js,mjs,ts,tsx}": "eslint --fix",
    "*.css": "stylelint --fix",
    "*.{html,css,js,mjs,ts,tsx,json,md}": "prettier --write"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.2",
    "concurrently": "^8.2.2",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.3",
    "prettier": "^3.8.3",
    "stylelint": "^17.11.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.11"
  }
}
