{
  "name": "ai-framework-gb",
  "version": "1.0.0",
  "private": true,
  "description": "AI newsletter site + Remotion ambient hero loop. One-command runner, deploy-safe for Railway and GitHub Pages.",
  "scripts": {
    "postinstall": "cd remotion-hero && npm install --no-audit --no-fund",
    "prepare": "husky",
    "render": "cd remotion-hero && npm run build",
    "render:webm": "cd remotion-hero && npm run build:webm",
    "render:if-missing": "node -e \"process.exit(require('fs').existsSync('remotion-hero/out/hero-ambient.mp4')?0:1)\" || npm run render",
    "build:prompts": "node scripts/build-prompts.mjs",
    "build:site": "npm run build:prompts && vite build",
    "build": "npm run render:if-missing && npm run build:site",
    "dev:web": "npm run build:prompts && vite --host 0.0.0.0 --port ${PORT:-5173}",
    "serve": "vite preview --host 0.0.0.0 --port ${PORT:-5173}",
    "studio": "cd remotion-hero && npm start",
    "start": "node scripts/start.js",
    "start:railway": "npm run serve",
    "dev": "concurrently -k -n web,studio -c green,blue \"npm run dev:web\" \"npm run studio\"",
    "force-render": "npm run render && npm run build:site && npm run serve",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:styles": "stylelint \"src/styles/**/*.css\"",
    "lint:staged": "lint-staged",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "lint-staged": {
    "*.{js,mjs,ts,tsx}": "eslint --fix",
    "*.css": "stylelint --fix",
    "*.{html,css,js,mjs,ts,tsx,json,md}": "prettier --write"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.1",
    "@types/node": "^22.19.18",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "stylelint": "^16.8.2",
    "stylelint-config-standard": "^36.0.1",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.21"
  }
}
